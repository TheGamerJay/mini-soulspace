# ─── Mini SoulSpace — environment template ───────────────────
# Copy to `.env` and adjust values. Never commit your real `.env`.

# ── Application ──────────────────────────────────────────────
APP_NAME=Mini SoulSpace
APP_PHASE=2
ENVIRONMENT=development
DEBUG=true

# ── Database (PostgreSQL + pgvector) ─────────────────────────
# Matches docker-compose defaults.
POSTGRES_USER=soulspace
POSTGRES_PASSWORD=soulspace
POSTGRES_DB=soulspace
DATABASE_URL=postgresql+psycopg://soulspace:soulspace@localhost:5432/soulspace

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Ollama / AI models ───────────────────────────────────────
OLLAMA_URL=http://localhost:11434
MAIN_MODEL=qwen3:14b
FAST_MODEL=llama3.1:8b
TAG_MODEL=gemma3:4b
CODER_MODEL=qwen2.5-coder:14b

# ── Security / CORS ──────────────────────────────────────────
SECRET_KEY=change-me-in-production
CORS_ORIGINS=["http://localhost:3000"]

# ── Auth / JWT (Phase 1) ─────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
# IMPORTANT: set COOKIE_SECURE=true in production (HTTPS). Auto-forced when
# ENVIRONMENT=production.
COOKIE_SECURE=false

# ── Registration policy ──────────────────────────────────────
# Minimum signup age. Set to 0 to disable the age gate entirely.
MIN_SIGNUP_AGE=13

# ── Rate limiting ────────────────────────────────────────────
RATE_LIMIT_ENABLED=true

# ── Frontend ─────────────────────────────────────────────────
# Empty in the unified deployment (same-origin /api). Set only when the
# frontend is hosted separately from the backend.
NEXT_PUBLIC_API_URL=
